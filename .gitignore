# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Downloaded data + generated index caches (runtime, per-vault)
assets/
.dictionary-index.json
.thesaurus-index.json
.wordnet-index.json
.sudachi-synonyms-index.json

# Local dictionary data should never be committed (user-provided / large)
*.tab
*.dic

# Exclude macOS Finder (System Explorer) View States
.DS_Store
