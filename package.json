{
	"name": "obsidian-japanese-thesaurus",
	"version": "1.0.7",
	"description": "Japanese thesaurus & local dictionary for Obsidian: select text to see synonyms (Sudachi synonym dictionary + Japanese WordNet) and Eijiro-style definitions in a side panel.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"japanese",
		"thesaurus",
		"dictionary",
		"sudachi",
		"wordnet"
	],
	"license": "0BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/kuromoji": "^0.1.3",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"iconv-lite": "^0.6.3",
		"kuromoji": "^0.1.2",
		"obsidian": "latest"
	}
}
